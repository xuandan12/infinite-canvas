{
  "framework": "vite",
  "installCommand": "cd web && bun install",
  "buildCommand": "cd web && bun run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/ark/**/*.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    {
      "source": "/api/ark/:path*",
      "destination": "/api/ark/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
